+#[component]
+fn CircularScoreGauge(score: f64) -> Element {
+    let percentage = (score / 36.0 * 100.0).min(100.0).max(0.0);
+    let radius = 40.0;
+    let circumference = 2.0 * std::f64::consts::PI * radius;
+    let stroke_dashoffset = circumference - (percentage / 100.0) * circumference;
+    
+    let color_class = if score >= 18.0 {
+        "stroke-purple-500"
+    } else {
+        "stroke-amber-500"
+    };
+
+    rsx! {
+        div { class: "relative flex items-center justify-center w-24 h-24",
+            svg { class: "w-full h-full transform -rotate-90", viewBox: "0 0 100 100",
+                circle {
+                    class: "stroke-slate-800",
+                    stroke_width: "8",
+                    fill: "transparent",
+                    r: "{radius}",
+                    cx: "50",
+                    cy: "50"
+                }
+                circle {
+                    class: "transition-all duration-1000 ease-out {color_class}",
+                    stroke_width: "8",
+                    stroke_dasharray: "{circumference}",
+                    stroke_dashoffset: "{stroke_dashoffset}",
+                    stroke_linecap: "round",
+                    fill: "transparent",
+                    r: "{radius}",
+                    cx: "50",
+                    cy: "50"
+                }
+            }
+            div { class: "absolute flex flex-col items-center justify-center",
+                span { class: "text-xl font-black text-slate-100 font-mono", "{score:.1}" }
+                span { class: "text-[9px] text-slate-500 font-medium uppercase tracking-wider", "/ 36" }
+            }
+        }
+    }
+}
+
 #[component]
